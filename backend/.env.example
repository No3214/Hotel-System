# ==========================================
# Kozbeyli Konagi Hotel System - Environment
# ==========================================
# Bu dosyayi .env olarak kopyalayin ve doldurun:
# cp .env.example .env

# ==================== ZORUNLU ====================
MONGO_URL=mongodb://localhost:27017
DB_NAME=kozbeyli_konagi

# ==================== ORTAM ====================
ENVIRONMENT=development
# development: Debug acik, API docs acik
# production: Debug kapali, API docs kapali
DEBUG=false
LOG_LEVEL=INFO

# ==================== GUVENLIK ====================
# JWT Secret - production'da mutlaka degistirin!
# openssl rand -hex 32 ile uretebilirsiniz
JWT_SECRET=BURAYA-GUCLU-BIR-SECRET-KOYUN
JWT_EXPIRE_SECONDS=86400
JWT_REFRESH_EXPIRE_SECONDS=604800

# CORS - virgul ile ayrilmis domainler
# Production'da: https://panel.kozbeylikonagi.com,https://kozbeylikonagi.com
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate Limiting
RATE_LIMIT_ENABLED=true

# ==================== AI / LLM ====================
GOOGLE_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
EMERGENT_LLM_KEY=

# ==================== WHATSAPP BUSINESS API ====================
# Meta Business Suite'ten alinir
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=

# ==================== SOSYAL MEDYA AUTO-PUBLISHER ====================
# Meta Graph API (Facebook + Instagram)
# Meta Business Suite > Settings > Access Tokens
META_PAGE_ACCESS_TOKEN=
META_PAGE_ID=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# X (Twitter) API v2
# developer.twitter.com > Projects > Keys and tokens
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# LinkedIn API
# linkedin.com/developers > My Apps > Auth
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORG_ID=
LINKEDIN_PERSON_ID=

# TikTok Content Posting API
# developers.tiktok.com > Manage Apps
TIKTOK_ACCESS_TOKEN=

# Pinterest API v5
# developers.pinterest.com > My Apps
PINTEREST_ACCESS_TOKEN=
PINTEREST_BOARD_ID=

# Google Business Profile API
# console.cloud.google.com > APIs > Business Profile
GOOGLE_BUSINESS_ACCESS_TOKEN=
GOOGLE_BUSINESS_LOCATION_ID=

# ==================== INSTAGRAM (Legacy) ====================
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_PAGE_ID=

# ==================== HOTELRUNNER ====================
# Legacy env vars (backward compatible)
HOTELRUNNER_API_KEY=
HOTELRUNNER_HOTEL_ID=
HOTELRUNNER_API_URL=https://app.hotelrunner.com/api/v2

# HotelRunner Live API - bu iki degeri girin, sistem otomatik live mode'a gecer
HOTELRUNNER_TOKEN=
HOTELRUNNER_HR_ID=

# ==================== REDIS (opsiyonel) ====================
REDIS_URL=
